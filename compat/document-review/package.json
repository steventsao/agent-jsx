{
  "name": "agent-jsx-document-review",
  "private": true,
  "type": "module",
  "description": "Generated Cloudflare Worker UI/API for the document review human-input example.",
  "scripts": {
    "generate": "cd scripts && bun generate.tsx",
    "typecheck": "bun run generate && tsc --noEmit",
    "test": "bun run generate && vitest run",
    "deploy": "bun run generate && wrangler deploy"
  },
  "dependencies": {
    "agents": "^0.8.5",
    "react": "^19.0.0",
    "unpdf": "^1.3.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.4",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "4.1.1",
    "wrangler": "^4.77.0"
  },
  "imports": {
    "#agentjsx/jsx-runtime": "./src/generated/runtime/jsx-runtime.ts",
    "#agentjsx/jsx-dev-runtime": "./src/generated/runtime/jsx-dev-runtime.ts"
  }
}
