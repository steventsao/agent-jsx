// Real worker config for the compat proof. Bindings/migrations mirror the
// emitter's generated fragment (src/generated/uptime.wrangler.jsonc). The
// compat date + nodejs runner flags match the cloudflare/agents test setup for
// agents 0.17.4 under vitest-pool-workers.
{
  "name": "agent-jsx-compat",
  "main": "src/worker.ts",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": [
    "nodejs_compat",
    "experimental",
    // the vitest-pool-workers runner needs these node modules enabled
    "enable_nodejs_tty_module",
    "enable_nodejs_fs_module",
    "enable_nodejs_http_modules",
    "enable_nodejs_perf_hooks_module",
    "enable_nodejs_v8_module",
    "enable_nodejs_process_v2"
  ],
  "durable_objects": {
    "bindings": [
      { "name": "UPTIME", "class_name": "UptimeDurable" },
      { "name": "INVESTIGATOR", "class_name": "InvestigatorDurable" },
      // continuation e2e (Phase 0): cont-root nests cont-emitter statically and
      // fans out cont-folder grandchildren via its render-prop continuation.
      { "name": "CONT_ROOT", "class_name": "ContRootDurable" },
      { "name": "CONT_EMITTER", "class_name": "ContEmitterDurable" },
      { "name": "CONT_FOLDER", "class_name": "ContFolderDurable" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["UptimeDurable", "InvestigatorDurable"] },
    {
      "tag": "v2",
      "new_sqlite_classes": ["ContRootDurable", "ContEmitterDurable", "ContFolderDurable"]
    }
  ]
}
