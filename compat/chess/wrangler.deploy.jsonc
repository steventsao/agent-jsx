{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-jsx-chess",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-15",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "ai": { "binding": "AI" },
  "durable_objects": {
    "bindings": [
      {
        "name": "CHESS_GAME",
        "class_name": "ChessGame",
        "script_name": "agent-jsx-chess"
      },
      {
        "name": "CHESS_MATCH",
        "class_name": "ChessMatchDurable",
        "script_name": "agent-jsx-chess"
      },
      {
        "name": "OPENAI_CHESS_PLAYER",
        "class_name": "OpenaiChessPlayerDurable",
        "script_name": "agent-jsx-chess"
      },
      {
        "name": "GEMINI_CHESS_PLAYER",
        "class_name": "GeminiChessPlayerDurable",
        "script_name": "agent-jsx-chess"
      }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ChessGame"] },
    {
      "tag": "v2",
      "new_sqlite_classes": [
        "ChessMatchDurable",
        "OpenaiChessPlayerDurable",
        "GeminiChessPlayerDurable"
      ]
    }
  ]
}
