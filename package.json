{
  "name": "agent-jsx",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#agentjsx/jsx-runtime": "./src/jsx-data-runtime.ts",
    "#agentjsx/jsx-dev-runtime": "./src/jsx-data-runtime.ts"
  },
  "description": "React's reconciler as an agent control plane: composition + behavior declared as components (props/state changes), priompt-style context rendering, execution left to the actor runtime.",
  "scripts": {
    "ex:uptime": "bun examples/uptime.tsx",
    "ex:rehydrate": "bun examples/rehydrate.tsx",
    "ex:verify": "bun examples/verify.tsx",
    "ex:document-review": "bun examples/document-review.tsx",
    "ex:layout-review": "bun examples/layout-review/demo.tsx",
    "all": "bun examples/uptime.tsx && bun examples/rehydrate.tsx && bun examples/verify.tsx && bun examples/document-review.tsx && bun examples/layout-review/demo.tsx && bun examples/compile.tsx",
    "compile:document-review": "cd compat/document-review && bun run generate",
    "test:document-review": "cd compat/document-review && bun run test",
    "deploy:document-review": "cd compat/document-review && bun run deploy",
    "gen:verify-fixture": "bun scripts/gen-verify-fixture.ts",
    "typecheck": "tsc --noEmit",
    "ex:compile": "bun examples/compile.tsx",
    "chess:generate": "bun examples/chess/generate.tsx",
    "chess:worker:test": "cd compat/chess && bun run test && bun run typecheck",
    "chess:worker:deploy": "cd compat/chess && bun run deploy",
    "fixtures": "bun scripts/gen-fixtures.tsx",
    "fixtures:pdf": "bun scripts/pdf/build-fixture.tsx"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "react": "^19.0.0",
    "react-reconciler": "^0.31.0",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-reconciler": "^0.28.9",
    "typescript": "^5.7.0"
  },
  "license": "Apache-2.0"
}
