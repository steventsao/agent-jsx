{
  "name": "@steventsao/agent-jsx",
  "version": "0.1.0-alpha.0",
  "description": "Compose typed agents as JSX and compile them to Cloudflare Agents, Cloudflare Think, or Flue.",
  "license": "Apache-2.0",
  "author": "Steven Tsao",
  "homepage": "https://github.com/steventsao/agent-jsx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steventsao/agent-jsx.git"
  },
  "bugs": {
    "url": "https://github.com/steventsao/agent-jsx/issues"
  },
  "keywords": [
    "agents",
    "ai",
    "cloudflare",
    "compiler",
    "jsx"
  ],
  "packageManager": "bun@1.3.2",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./agent": {
      "types": "./dist/agent-class.d.ts",
      "import": "./dist/agent-class.js",
      "default": "./dist/agent-class.js"
    },
    "./agent-component": {
      "types": "./dist/agent-component.d.ts",
      "import": "./dist/agent-component.js",
      "default": "./dist/agent-component.js"
    },
    "./compile/emit-agent-module": {
      "types": "./dist/compile/emit-agent-module.d.ts",
      "import": "./dist/compile/emit-agent-module.js",
      "default": "./dist/compile/emit-agent-module.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-data-runtime.d.ts",
      "import": "./dist/jsx-data-runtime.js",
      "default": "./dist/jsx-data-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-data-runtime.d.ts",
      "import": "./dist/jsx-data-runtime.js",
      "default": "./dist/jsx-data-runtime.js"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#agentjsx/jsx-runtime": "./src/jsx-data-runtime.ts",
    "#agentjsx/jsx-dev-runtime": "./src/jsx-data-runtime.ts"
  },
  "scripts": {
    "build": "bun run clean && bun run build:js && bun run build:types",
    "build:js": "bun build --target=node --format=esm --packages=external --sourcemap=external --outdir=dist --root=src src/agent-class.tsx src/agent-component.tsx src/compile/emit-agent-module.ts src/jsx-data-runtime.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "clean": "bun -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "test": "bun test tests",
    "check": "bun run typecheck && bun run test",
    "package:check": "bun run build && publint && attw --pack . --profile esm-only && node scripts/verify-package.mjs",
    "ci": "bun run check && bun run package:check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run package:check && changeset publish",
    "ex:uptime": "bun examples/uptime.tsx",
    "ex:rehydrate": "bun examples/rehydrate.tsx",
    "ex:verify": "bun examples/verify.tsx",
    "ex:document-review": "bun examples/document-review.tsx",
    "ex:layout-review": "bun examples/layout-review/demo.tsx",
    "ex:trading": "bun examples/trading-desk/demo.tsx",
    "all": "bun examples/uptime.tsx && bun examples/rehydrate.tsx && bun examples/verify.tsx && bun examples/document-review.tsx && bun examples/layout-review/demo.tsx && bun examples/compile.tsx && bun examples/trading-desk/demo.tsx",
    "compile:document-review": "cd compat/document-review && bun run generate",
    "test:document-review": "cd compat/document-review && bun run test",
    "deploy:document-review": "cd compat/document-review && bun run deploy",
    "gen:verify-fixture": "bun scripts/gen-verify-fixture.ts",
    "typecheck": "tsc --noEmit",
    "ex:compile": "bun examples/compile.tsx",
    "chess:generate": "bun examples/chess/generate.tsx",
    "chess:worker:test": "cd compat/chess && bun run test && bun run typecheck",
    "chess:worker:deploy": "cd compat/chess && bun run deploy",
    "fixtures": "bun scripts/gen-fixtures.tsx",
    "fixtures:pdf": "bun scripts/pdf/build-fixture.tsx"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "react-reconciler": "^0.31.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-reconciler": "^0.28.9",
    "chess.js": "^1.4.0",
    "publint": "0.3.21",
    "react": "^19.0.0",
    "typescript": "^5.7.0",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  }
}
