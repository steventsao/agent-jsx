{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "types": [
      "node",
      "bun"
    ]
  },
  "include": [
    "src",
    "examples",
    "tests",
    "scripts",
    "targets"
  ],
  "exclude": [
    "examples/generated",
    "examples/chess/generated",
    "compat"
  ]
}
